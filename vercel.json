{
  "version": 2,
  "routes": [
    { "src": "/", "dest": "/index.html" },
    { "src": "/services", "dest": "/services.html" },
    { "src": "/services.html", "dest": "/services.html" },
    { "src": "/free-tools", "status": 301, "dest": "/" },
    { "src": "/free-tools.html", "status": 301, "dest": "/" },
    { "src": "/analytics", "dest": "https://analytics.eduxellence.org" },
    { "src": "/stats", "dest": "https://stats.eduxellence.org" },
    { "src": "/clean", "dest": "https://clean.eduxellence.org" },
    { "src": "/results", "dest": "https://results.eduxellence.org" },
    { "src": "/(.*)", "dest": "/$1" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
